{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "es2020",
    "target": "ES2020",
    "jsx": "react-jsx",
    "declaration": true,
    "declarationDir": "dist",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": "src",
    "paths": {
      "@components/*": ["components/*"],
      "@providers/*": ["providers/*"]
    }
  },
  "include": ["src"]
}