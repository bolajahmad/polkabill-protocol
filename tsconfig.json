{
  "files": [],
  "references": [
    {
      "path": "./packages/sdk-core"
    },
    {
      "path": "./packages/sdk-react"
    }
  ],
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "nodenext",
    "declaration": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@polkabill/sdk-core": [
        "packages/sdk-core/src"
      ],
      "@polkabill/react": [
        "packages/sdk-react/src"
      ]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "exclude": [
    "node_modules",
    "dist"
  ]
}